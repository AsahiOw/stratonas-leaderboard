generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String
  role          Role      @default(VIEWER)
  sessions      Session[]
  accounts      Account[]
}

enum Role {
  ADMIN
  VIEWER
}

model Player {
  id               String       @id @default(cuid())
  ign              String
  username         String       @unique
  isGuildMember    Boolean      @default(true)
  favouriteStudent String?
  favouriteStudentId Int?
  favouriteStudentData Student? @relation(fields: [favouriteStudentId], references: [id], onDelete: SetNull)
  joinedDate       DateTime     @default(now())
  club             String?
  clubID           String?
  clubId           String?
  clubData         Club?        @relation(fields: [clubId], references: [id], onDelete: SetNull)
  userID           String?      @unique
  entries          RaidEntry[]

  @@index([ign])
  @@index([favouriteStudentId])
  @@index([clubId])
}

model Club {
  id        String   @id @default(cuid())
  name      String   @unique
  uid       String?
  logo      String?
  color     String   @default("#4f8ef7")
  players   Player[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id              Int      @id
  name            String
  image           String
  portrait        String?
  memorial        String?
  familyName      String?
  personalName    String?
  school          String?
  club            String?
  schoolYear      String?
  characterAge    String?
  birthday        String?
  birthDay        String?
  hobby           String?
  heightMetric    String?
  weaponType      String?
  tacticRole      String?
  position        String?
  weaponName      String?
  memorialOffsetX Float    @default(-7.6)
  memorialOffsetY Float    @default(0)
  memorialScale   Float    @default(0.5)
  portraitOffsetX Float    @default(0)
  portraitOffsetY Float    @default(0)
  portraitScale   Float    @default(1)
  favoritedBy     Player[]

  @@index([name])
  @@index([birthDay])
}

model StudentImportState {
  id          String    @id @default("schaledb-students")
  status      String    @default("idle")
  total       Int       @default(0)
  processed   Int       @default(0)
  added       Int       @default(0)
  skipped     Int       @default(0)
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model RaidBoss {
  id          String  @id @default(cuid())
  schaleId    Int?    @unique
  name        String  @unique
  description String  @default("")
  image       String?
  color       String  @default("#4f8ef7")
  color2      String  @default("#7c3aed")
  pattern     String  @default("hex")
  raids       Raid[]
}

model RaidBossImportState {
  id          String    @id @default("schaledb-raid-bosses")
  status      String    @default("idle")
  total       Int       @default(0)
  processed   Int       @default(0)
  added       Int       @default(0)
  skipped     Int       @default(0)
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model RaidType {
  id    String @id @default(cuid())
  name  String @unique
  raids Raid[]
}

model RaidServer {
  id    String @id @default(cuid())
  name  String @unique
  raids Raid[]
}

model RaidTerrain {
  id    String @id @default(cuid())
  name  String @unique
  raids Raid[]
}

model Raid {
  id         String     @id @default(cuid())
  raidBoss   RaidBoss   @relation(fields: [raidBossId], references: [id])
  raidBossId String
  season     Int
  type       RaidType   @relation(fields: [typeId], references: [id])
  typeId     String
  server     RaidServer @relation(fields: [serverId], references: [id])
  serverId   String
  terrain    RaidTerrain @relation(fields: [terrainId], references: [id])
  terrainId  String
  color      String     @default("#4f8ef7")
  color2     String     @default("#7c3aed")
  pattern    String     @default("hex")
  startDate  DateTime?
  endDate    DateTime?
  entries    RaidEntry[]
}

model RaidEntry {
  id        String   @id @default(cuid())
  player    Player   @relation(fields: [playerId], references: [id])
  playerId  String
  raid      Raid     @relation(fields: [raidId], references: [id])
  raidId    String
  score     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, raidId])
}

// NextAuth required models
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
