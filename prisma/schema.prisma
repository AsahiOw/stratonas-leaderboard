generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String
  role          Role      @default(VIEWER)
  sessions      Session[]
  accounts      Account[]
}

enum Role {
  ADMIN
  VIEWER
}

model Player {
  id               String       @id @default(cuid())
  ign              String
  username         String       @unique
  isGuildMember    Boolean      @default(true)
  favouriteStudent String?
  favouriteStudentId Int?
  favouriteStudentData Student? @relation(fields: [favouriteStudentId], references: [id], onDelete: SetNull)
  joinedDate       DateTime     @default(now())
  club             String?
  clubID           String?
  clubId           String?
  clubData         Club?        @relation(fields: [clubId], references: [id], onDelete: SetNull)
  userID           String?      @unique
  entries          RaidEntry[]
  xlsxReviewItems  XlsxImportReviewItem[]

  @@index([ign])
  @@index([favouriteStudentId])
  @@index([clubId])
}

model Club {
  id        String   @id @default(cuid())
  name      String   @unique
  uid       String?
  logo      String?
  color     String   @default("#4f8ef7")
  players   Player[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id              Int      @id
  name            String
  image           String
  portrait        String?
  memorial        String?
  familyName      String?
  personalName    String?
  school          String?
  club            String?
  schoolYear      String?
  characterAge    String?
  characterVoice  String?
  birthday        String?
  birthDay        String?
  hobby           String?
  heightMetric    String?
  weaponType      String?
  tacticRole      String?
  position        String?
  weaponName      String?
  accentColor     String?
  memorialOffsetX Float    @default(-7.6)
  memorialOffsetY Float    @default(0)
  memorialScale   Float    @default(0.5)
  portraitOffsetX Float    @default(0)
  portraitOffsetY Float    @default(0)
  portraitScale   Float    @default(1)
  favoritedBy     Player[]
  recruitments    Recruitment[]
  aliases         StudentAlias[]
  suggestedReviewItems XlsxImportReviewItem[] @relation("SuggestedStudentReview")
  resolvedReviewItems  XlsxImportReviewItem[] @relation("ResolvedStudentReview")

  @@index([name])
  @@index([birthDay])
}

model Recruitment {
  id             String                    @id @default(cuid())
  studentId      Int
  student        Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  bannerPath     String
  animationPath  String
  upcomingItems  UpcomingRecruitmentItem[]
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  @@unique([studentId])
}

model UpcomingRecruitment {
  id        String                    @id @default(cuid())
  dateKey   String                    @unique
  items     UpcomingRecruitmentItem[]
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  @@index([dateKey])
}

model UpcomingRecruitmentItem {
  upcomingRecruitmentId String
  recruitmentId         String
  position              Int                 @default(0)
  upcomingRecruitment   UpcomingRecruitment @relation(fields: [upcomingRecruitmentId], references: [id], onDelete: Cascade)
  recruitment           Recruitment         @relation(fields: [recruitmentId], references: [id], onDelete: Cascade)

  @@id([upcomingRecruitmentId, recruitmentId])
  @@index([recruitmentId])
}

model StudentAlias {
  id              String   @id @default(cuid())
  alias           String
  normalizedAlias String   @unique
  studentId       Int
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([studentId])
}

model StudentMatchRule {
  id                String   @id @default(cuid())
  type              String
  pattern           String
  normalizedPattern String
  value             String   @default("")
  normalizedValue   String   @default("")
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([type, normalizedPattern, normalizedValue])
  @@index([type, enabled])
}

model StudentImportState {
  id          String    @id @default("schaledb-students")
  status      String    @default("idle")
  total       Int       @default(0)
  processed   Int       @default(0)
  added       Int       @default(0)
  skipped     Int       @default(0)
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model RaidBoss {
  id          String  @id @default(cuid())
  schaleId    Int?    @unique
  name        String  @unique
  description String  @default("")
  image       String?
  color       String  @default("#4f8ef7")
  color2      String  @default("#7c3aed")
  pattern     String  @default("hex")
  raids       Raid[]
}

model RaidBossImportState {
  id          String    @id @default("schaledb-raid-bosses")
  status      String    @default("idle")
  total       Int       @default(0)
  processed   Int       @default(0)
  added       Int       @default(0)
  skipped     Int       @default(0)
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model MemorialMediaSyncState {
  id                 String    @id @default("jaymie-memorial-media")
  status             String    @default("idle")
  stage              String    @default("idle")
  total              Int       @default(0)
  processed          Int       @default(0)
  discovered         Int       @default(0)
  newVideos          Int       @default(0)
  downloaded         Int       @default(0)
  optimized          Int       @default(0)
  posters            Int       @default(0)
  skipped            Int       @default(0)
  currentItem        String?
  message            String?
  error              String?
  lastScheduledRunAt DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model MemorialVideoAsset {
  id                String    @id @default(cuid())
  youtubeId         String?   @unique
  title             String
  fileName          String?   @unique
  youtubeUrl        String?
  videoUrl          String?
  posterUrl         String?
  status            String    @default("discovered")
  downloadedAt      DateTime?
  optimizedAt       DateTime?
  posterGeneratedAt DateTime?
  error             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status])
  @@index([title])
}

model RaidType {
  id    String @id @default(cuid())
  name  String @unique
  raids Raid[]
}

model RaidServer {
  id    String @id @default(cuid())
  name  String @unique
  raids Raid[]
}

model RaidTerrain {
  id    String @id @default(cuid())
  name  String @unique
  raids Raid[]
}

model Raid {
  id         String     @id @default(cuid())
  raidBoss   RaidBoss   @relation(fields: [raidBossId], references: [id])
  raidBossId String
  season     Int
  type       RaidType   @relation(fields: [typeId], references: [id])
  typeId     String
  server     RaidServer @relation(fields: [serverId], references: [id])
  serverId   String
  terrain    RaidTerrain @relation(fields: [terrainId], references: [id])
  terrainId  String
  color      String     @default("#4f8ef7")
  color2     String     @default("#7c3aed")
  pattern    String     @default("hex")
  startDate  DateTime?
  endDate    DateTime?
  entries    RaidEntry[]
  xlsxReviewItems XlsxImportReviewItem[]
}

model RaidEntry {
  id        String   @id @default(cuid())
  player    Player   @relation(fields: [playerId], references: [id])
  playerId  String
  raid      Raid     @relation(fields: [raidId], references: [id])
  raidId    String
  score     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([playerId, raidId])
}

model XlsxImportReviewItem {
  id                           String   @id @default(cuid())
  raidId                       String
  raid                         Raid     @relation(fields: [raidId], references: [id], onDelete: Cascade)
  playerId                     String
  player                       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  rawFavoriteStudent           String?
  normalizedRawFavoriteStudent String   @default("")
  pfpUrl                       String?
  suggestedStudentId           Int?
  suggestedStudent             Student? @relation("SuggestedStudentReview", fields: [suggestedStudentId], references: [id], onDelete: SetNull)
  suggestedConfidence          Float?
  status                       String   @default("pending")
  resolvedStudentId            Int?
  resolvedStudent              Student? @relation("ResolvedStudentReview", fields: [resolvedStudentId], references: [id], onDelete: SetNull)
  resolvedAt                   DateTime?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  @@index([status, createdAt])
  @@index([raidId])
  @@index([playerId])
  @@index([suggestedStudentId])
  @@index([resolvedStudentId])
}

// NextAuth required models
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
