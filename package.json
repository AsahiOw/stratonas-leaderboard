{
  "name": "stratonas-leaderboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postgres:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local-postgres.ps1",
    "postgres:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-local-postgres.ps1",
    "db:docker:start": "docker-compose up -d db",
    "db:docker:stop": "docker-compose stop db",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "ts-node --project tsconfig.seed.json prisma/seed.ts",
    "admin:create": "ts-node --project tsconfig.seed.json prisma/create-admin.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "next": "14.2.21",
    "next-auth": "^5.0.0-beta.25",
    "react": "^18",
    "react-dom": "^18"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.21",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
