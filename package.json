{
  "name": "stratonas-leaderboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test:student-lookup": "ts-node --project tsconfig.seed.json src/lib/student-name-matcher.test.ts",
    "test:chat-agent": "ts-node --project tsconfig.seed.json src/lib/chat-agent.test.ts",
    "postgres:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local-postgres.ps1",
    "postgres:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-local-postgres.ps1",
    "db:docker:start": "docker-compose up -d db",
    "db:docker:stop": "docker-compose stop db",
    "db:migrate": "set -a; . ./.env.docker; set +a; DATABASE_URL=$(printf '%s' \"$DATABASE_URL\" | sed 's/@db:5432/@localhost:5432/'); prisma migrate deploy",
    "db:migrate:docker": "set -a; . ./.env.docker; set +a; prisma migrate deploy",
    "db:seed": "set -a; . ./.env.docker; set +a; DATABASE_URL=$(printf '%s' \"$DATABASE_URL\" | sed 's/@db:5432/@localhost:5432/'); tsx prisma/seed.ts",
    "db:seed:docker": "set -a; . ./.env.docker; set +a; tsx prisma/seed.ts",
    "admin:create": "set -a; . ./.env.docker; set +a; DATABASE_URL=$(printf '%s' \"$DATABASE_URL\" | sed 's/@db:5432/@localhost:5432/'); tsx prisma/create-admin.ts",
    "admin:create:docker": "set -a; . ./.env.docker; set +a; tsx prisma/create-admin.ts",
    "media:memorials": "tsx scripts/memorial-media-sync.ts",
    "media:process-existing": "tsx scripts/memorial-media-sync.ts --process-existing",
    "media:videos:backfill": "tsx scripts/backfill-memorial-video-assets.ts",
    "wiki:memorials": "set -a; . ./.env.docker; set +a; DATABASE_URL=$(printf '%s' \"$DATABASE_URL\" | sed 's/@db:5432/@localhost:5432/'); tsx scripts/scrape-memorial-lobbies.ts",
    "wiki:memorials:docker": "set -a; . ./.env.docker; set +a; tsx scripts/scrape-memorial-lobbies.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "lucide-react": "^1.23.0",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "react": "^18",
    "react-dom": "^18"
  },
  "prisma": {
    "seed": "ts-node --project tsconfig.seed.json prisma/seed.ts"
  },
  "overrides": {
    "postcss": "$postcss"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.12",
    "prisma": "^7.8.0",
    "puppeteer": "^22.15.0",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
